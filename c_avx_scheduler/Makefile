# =============================================================================
# Makefile — Stochastic Online Scheduler (AVX-512 / Intel Xeon Sapphire Rapids)
# =============================================================================

# ── Toolchain ─────────────────────────────────────────────────────────────
CXX     ?= g++
AR      ?= ar
OBJDUMP ?= objdump

# ── Project identity ──────────────────────────────────────────────────────
PROJECT  := scheduler_avx512
VERSION  := 1.0.0

# ── Directory structure ───────────────────────────────────────────────────
SRC_DIR  := .
INC_DIR  := .
OBJ_DIR  := build/release
OBJ_DBG  := build/debug
BIN_DIR  := bin

# ── Source files (order determines link order) ────────────────────────────
SOURCES  := \
    $(SRC_DIR)/cost_calculator.cpp \
    $(SRC_DIR)/job_info_update.cpp \
    $(SRC_DIR)/virtual_fifo.cpp \
    $(SRC_DIR)/scheduler.cpp \
    $(SRC_DIR)/ext_mem_interface.cpp \
    $(SRC_DIR)/ext_mem_host.cpp

# ── Header files ──────────────────────────────────────────────────────────
HEADERS  := \
    $(INC_DIR)/data_types.hpp \
    $(INC_DIR)/extm_data_types.hpp \
    $(INC_DIR)/top_modules.hpp \
    $(INC_DIR)/virtual_fifo.hpp

# ── Derived object lists ──────────────────────────────────────────────────
OBJS_REL := $(patsubst $(SRC_DIR)/%.cpp, $(OBJ_DIR)/%.o, $(SOURCES))
OBJS_DBG := $(patsubst $(SRC_DIR)/%.cpp, $(OBJ_DBG)/%.o, $(SOURCES))

# ── Dependency files (auto-generated by -MMD) ─────────────────────────────
DEPS_REL := $(OBJS_REL:.o=.d)
DEPS_DBG := $(OBJS_DBG:.o=.d)

# ── Binary names ──────────────────────────────────────────────────────────
BIN_REL  := $(BIN_DIR)/$(PROJECT)
BIN_DBG  := $(BIN_DIR)/$(PROJECT)_debug

# =============================================================================
# Compiler flags
# =============================================================================

# ── C++ standard ──────────────────────────────────────────────────────────
CXXSTD   := -std=c++17
INCLUDES := -I$(INC_DIR)

# ── ISA selection: Intel Xeon 4th-gen "Sapphire Rapids" ───────────────────
MARCH_PRIMARY  := -march=sapphirerapids -mno-avx512fp16
MARCH_FALLBACK := -mavx512f -mavx512bw -mavx512vl -mavx512dq -mavx512cd -mavx2 -mbmi2 -mpopcnt

GCC_VER := $(shell $(CXX) -dumpversion 2>/dev/null | cut -d. -f1)
GCC_VER_OK := $(shell [ "$(GCC_VER)" -ge 12 ] 2>/dev/null && echo yes || echo no)

ifeq ($(GCC_VER_OK),yes)
    MARCH_FLAGS := $(MARCH_PRIMARY)
else
    MARCH_FLAGS := $(MARCH_FALLBACK)
endif

ifdef MARCH
    MARCH_FLAGS := $(MARCH)
endif

# ── Common warning flags ──────────────────────────────────────────────────
WARN_FLAGS := \
    -Wall \
    -Wextra \
    -Wshadow \
    -Wno-unused-function \
    -Wno-unused-variable \
    -Wcast-align \
    -Wformat=2

# ── Release optimisation flags ────────────────────────────────────────────
OPT_FLAGS_REL := \
    -O3 \
    -funroll-loops \
    -ffast-math \
    -fprefetch-loop-arrays \
    -falign-loops=32 \
    -fomit-frame-pointer \
    -DNDEBUG \
    -DDEBUG=0

# ── Debug flags ───────────────────────────────────────────────────────────
OPT_FLAGS_DBG := \
    -O0 \
    -g3 \
    -ggdb \
    -fsanitize=address,undefined \
    -fno-omit-frame-pointer \
    -DDEBUG=1

# ── Link flags ────────────────────────────────────────────────────────────
LDFLAGS_REL  := -lpthread -lm
LDFLAGS_DBG  := -lpthread -lm -fsanitize=address,undefined

# ── Assembled flag sets ───────────────────────────────────────────────────
CXXFLAGS_REL := $(CXXSTD) $(INCLUDES) $(MARCH_FLAGS) $(WARN_FLAGS) $(OPT_FLAGS_REL) -MMD -MP
CXXFLAGS_DBG := $(CXXSTD) $(INCLUDES) $(MARCH_FLAGS) $(WARN_FLAGS) $(OPT_FLAGS_DBG) -MMD -MP

# =============================================================================
# Build rules
# =============================================================================

.PHONY: all release debug clean distclean check_cpu info disasm

all: release

release: $(BIN_REL)
	@echo ""
	@echo "  ✓ Release binary: $(BIN_REL)"
	@echo "    ISA flags: $(MARCH_FLAGS)"
	@echo ""

debug: $(BIN_DBG)
	@echo ""
	@echo "  ✓ Debug binary:   $(BIN_DBG)"
	@echo "    Sanitisers: AddressSanitizer + UBSan enabled"
	@echo ""

$(OBJ_DIR) $(OBJ_DBG) $(BIN_DIR):
	@mkdir -p $@

$(BIN_REL): $(OBJS_REL) | $(BIN_DIR)
	@echo "  [LD-REL]  $@"
	$(CXX) $(CXXFLAGS_REL) $^ -o $@ $(LDFLAGS_REL)

$(BIN_DBG): $(OBJS_DBG) | $(BIN_DIR)
	@echo "  [LD-DBG]  $@"
	$(CXX) $(CXXFLAGS_DBG) $^ -o $@ $(LDFLAGS_DBG)

$(OBJ_DIR)/%.o: $(SRC_DIR)/%.cpp | $(OBJ_DIR)
	@echo "  [CXX-REL] $<"
	$(CXX) $(CXXFLAGS_REL) -c $< -o $@

$(OBJ_DBG)/%.o: $(SRC_DIR)/%.cpp | $(OBJ_DBG)
	@echo "  [CXX-DBG] $<"
	$(CXX) $(CXXFLAGS_DBG) -c $< -o $@

# =============================================================================
# Utility targets
# =============================================================================

clean:
	@echo "  [CLEAN] Removing build/ and bin/"
	@rm -rf build/ bin/

distclean: clean
	@echo "  [DISTCLEAN] Done."

check_cpu:
	@echo "  [CHECK_CPU] Probing CPUID on this machine..."
	@echo '#include <cstdio>' > /tmp/_check_cpu.cpp
	@echo '#include <cstdint>' >> /tmp/_check_cpu.cpp
	@echo 'int main() {' >> /tmp/_check_cpu.cpp
	@echo '    uint32_t eax=7,ebx=0,ecx=0,edx=0;' >> /tmp/_check_cpu.cpp
	@echo '    __asm__("cpuid":"=a"(eax),"=b"(ebx),"=c"(ecx),"=d"(edx):"a"(7),"c"(0));' >> /tmp/_check_cpu.cpp
	@echo '    printf("AVX2      : %s\n", (ebx>>5 &1)?"YES":"NO");' >> /tmp/_check_cpu.cpp
	@echo '    printf("AVX-512F  : %s\n", (ebx>>16&1)?"YES":"NO");' >> /tmp/_check_cpu.cpp
	@echo '    printf("AVX-512BW : %s\n", (ebx>>30&1)?"YES":"NO");' >> /tmp/_check_cpu.cpp
	@echo '    printf("AVX-512VL : %s\n", (ebx>>31&1)?"YES":"NO");' >> /tmp/_check_cpu.cpp
	@echo '    return 0;' >> /tmp/_check_cpu.cpp
	@echo '}' >> /tmp/_check_cpu.cpp
	@$(CXX) -std=c++17 -O0 /tmp/_check_cpu.cpp -o /tmp/_check_cpu_$(PROJECT)
	@/tmp/_check_cpu_$(PROJECT)
	@rm -f /tmp/_check_cpu.cpp /tmp/_check_cpu_$(PROJECT)

disasm: $(BIN_REL)
	@echo "  [DISASM] Searching for AVX-512 (EVEX) instructions in $(BIN_REL)"
	$(OBJDUMP) -d --no-show-raw-insn $(BIN_REL) | grep -E 'zmm|vmovdqa|vmovdqu|vpbroadcast|vpcmpeq|vpcmpgt|vpternlog|vpmask' | head -60
	@echo "  (truncated to 60 lines — run objdump -d $(BIN_REL) | less for full output)"

info:
	@echo "========================================================"
	@echo "  Project  : $(PROJECT) v$(VERSION)"
	@echo "  Compiler : $(CXX) (GCC major version: $(GCC_VER))"
	@echo "  C++ Std  : $(CXXSTD)"
	@echo "  ISA      : $(MARCH_FLAGS)"
	@echo "  Rel opt  : $(OPT_FLAGS_REL)"
	@echo "  Dbg opt  : $(OPT_FLAGS_DBG)"
	@echo "========================================================"

-include $(DEPS_REL)
-include $(DEPS_DBG)
